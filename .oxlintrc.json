{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-explicit-any": "warn",
    "eslint/no-unused-vars": "warn",
    "eslint/prefer-const": "error"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "src/routeTree.gen.ts"
  ]
}